# NeoKarir Environment Variables Example

# Base URL for main backend API (e.g. Node.js Express)
VITE_API_URL=http://localhost:5000/api

# Base URL for AI Model Service (e.g. FastAPI)
VITE_AI_URL=http://localhost:8000

# Toggle to use mock data instead of real API endpoints. 
# Set to 'true' to develop frontend offline, or 'false' to connect to live backend.
VITE_USE_MOCK=true
